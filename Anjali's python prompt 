        "import pandas as pd # Import the pandas library for DataFrame operations\n",
        "import os # Import the os module for interacting with the operating system (e.g., checking file existence)\n",
        "\n",
        "# --- 1. Variables ---\n",
        "# Variables are used to store data values.\n",
        "my_string = \"Hello, Python!\" # A string variable to hold text.\n",
        "my_integer = 100 # An integer variable to hold whole numbers.\n",
        "my_float = 3.14 # A float variable to hold decimal numbers.\n",
        "my_boolean = True # A boolean variable to hold True or False.\n",
        "\n",
        "print(\"--- Variables ---\")\n",
        "print(f\"String: {my_string}\")\n",
        "print(f\"Integer: {my_integer}\")\n",
        "print(f\"Float: {my_float}\")\n",
        "print(f\"Boolean: {my_boolean}\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 2. Lists ---\n",
        "# Lists are ordered, mutable (changeable) collections of items. They allow duplicate members.\n",
        "my_list = [\"apple\", \"banana\", \"cherry\", \"apple\"]\n",
        "print(\"--- Lists ---\")\n",
        "print(f\"Original List: {my_list}\")\n",
        "my_list.append(\"date\") # Add an item to the end of the list.\n",
        "print(f\"List after append: {my_list}\")\n",
        "print(f\"First item: {my_list[0]}\") # Access items by index (0-based).\n",
        "\n",
        "# Iterate through a list using a for loop.\n",
        "print(\"Iterating through list:\")\n",
        "for item in my_list:\n",
        "    print(f\"  {item}\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 3. Tuples ---\n",
        "# Tuples are ordered, immutable (unchangeable) collections of items. They allow duplicate members.\n",
        "my_tuple = (\"red\", \"green\", \"blue\", \"red\")\n",
        "print(\"--- Tuples ---\")\n",
        "print(f\"Original Tuple: {my_tuple}\")\n",
        "print(f\"Second item: {my_tuple[1]}\") # Access items by index.\n",
        "# my_tuple.append(\"yellow\") # This would cause an error because tuples are immutable.\n",
        "print(\"Iterating through tuple:\")\n",
        "for color in my_tuple:\n",
        "    print(f\"  {color}\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 4. Dictionaries ---\n",
        "# Dictionaries are unordered, mutable collections of key-value pairs. Keys must be unique.\n",
        "my_dict = {\"name\": \"Alice\", \"age\": 30, \"city\": \"New York\"}\n",
        "print(\"--- Dictionaries ---\")\n",
        "print(f\"Original Dictionary: {my_dict}\")\n",
        "my_dict[\"age\"] = 31 # Modify an existing value.\n",
        "my_dict[\"occupation\"] = \"Engineer\" # Add a new key-value pair.\n",
        "print(f\"Dictionary after modification: {my_dict}\")\n",
        "print(f\"Alice's age: {my_dict['age']}\") # Access value by key.\n",
        "\n",
        "# Iterate through a dictionary.\n",
        "print(\"Iterating through dictionary (keys and values):\")\n",
        "for key, value in my_dict.items():\n",
        "    print(f\"  {key}: {value}\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 5. Sets ---\n",
        "# Sets are unordered, mutable collections of unique items. Duplicates are automatically removed.\n",
        "my_set = {\"cat\", \"dog\", \"bird\", \"cat\"}\n",
        "print(\"--- Sets ---\")\n",
        "print(f\"Original Set (duplicates removed): {my_set}\")\n",
        "my_set.add(\"fish\") # Add an item to the set.\n",
        "print(f\"Set after add: {my_set}\")\n",
        "\n",
        "another_set = {\"dog\", \"elephant\", \"mouse\"}\n",
        "print(f\"Another Set: {another_set}\")\n",
        "print(f\"Union of sets: {my_set.union(another_set)}\") # Combine sets.\n",
        "print(f\"Intersection of sets: {my_set.intersection(another_set)}\") # Find common items.\n",
        "print(\"Iterating through set:\")\n",
        "for animal in my_set:\n",
        "    print(f\"  {animal}\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 6. For Loops ---\n",
        "# Used for iterating over a sequence (list, tuple, dictionary, set, string, or range).\n",
        "print(\"--- For Loops ---\")\n",
        "print(\"Counting with for loop (range):\")\n",
        "for i in range(3): # range(3) generates numbers 0, 1, 2.\n",
        "    print(f\"  Count: {i}\")\n",
        "\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 7. While Loops ---\n",
        "# Repeats a block of code as long as a condition is true.\n",
        "print(\"--- While Loops ---\")\n",
        "count = 0\n",
        "while count < 3:\n",
        "    print(f\"  While count: {count}\")\n",
        "    count += 1 # Increment count to eventually make the condition false.\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 8. Functions ---\n",
        "# Functions are blocks of reusable code that perform a specific task.\n",
        "# Define a simple function with parameters and a return value.\n",
        "def add_numbers(a, b):\n",
        "    \"\"\"This function takes two numbers and returns their sum.\"\"\"\n",
        "    return a + b\n",
        "\n",
        "def greet(name=\"Guest\"):\n",
        "    \"\"\"This function prints a greeting with an optional name.\"\"\"\n",
        "    print(f\"  Hello, {name}!\")\n",
        "\n",
        "print(\"--- Functions ---\")\n",
        "sum_result = add_numbers(5, 7)\n",
        "print(f\"  Sum of 5 and 7: {sum_result}\")\n",
        "greet(\"Bob\") # Call greet with a name.\n",
        "greet() # Call greet without a name (uses default).\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 9. Exception Handling ---\n",
        "# Used to handle errors gracefully, preventing program crashes.\n",
        "print(\"--- Exception Handling ---\")\n",
        "# Example 1: Division by zero.\n",
        "try:\n",
        "    result = 10 / 0 # This will cause a ZeroDivisionError.\n",
        "    print(f\"  Result: {result}\")\n",
        "except ZeroDivisionError:\n",
        "    print(\"  Error: Cannot divide by zero!\")\n",
        "except TypeError:\n",
        "    print(\"  Error: Type mismatch!\") # Catch a different potential error.\n",
        "except Exception as e:\n",
        "    print(f\"  An unexpected error occurred: {e}\") # Catch any other error.\n",
        "finally:\n",
        "    print(\"  Division attempt finished.\") # This block always executes.\n",
        "\n",
        "# Example 2: File not found.\n",
        "file_name = \"non_existent_file.txt\"\n",
        "try:\n",
        "    with open(file_name, 'r') as f:\n",
        "        content = f.read()\n",
        "        print(f\"  File content: {content}\")\n",
        "except FileNotFoundError:\n",
        "    print(f\"  Error: File '{file_name}' not found.\")\n",
        "finally:\n",
        "    print(f\"  Attempt to read '{file_name}' finished.\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 10. File Handling ---\n",
        "# Reading from and writing to files.\n",
        "print(\"--- File Handling ---\")\n",
        "output_file = \"my_output.txt\"\n",
        "\n",
        "# Writing to a file.\n",
        "try:\n",
        "    with open(output_file, 'w') as f: # 'w' mode opens for writing (creates if not exists, overwrites if exists).\n",
        "        f.write(\"This is the first line.\\n\")\n",
        "        f.write(\"This is the second line.\\n\")\n",
        "    print(f\"  Successfully wrote to '{output_file}'.\")\n",
        "except IOError as e:\n",
        "    print(f\"  Error writing to file: {e}\")\n",
        "\n",
        "# Reading from a file.\n",
        "try:\n",
        "    with open(output_file, 'r') as f: # 'r' mode opens for reading.\n",
        "        read_content = f.read()\n",
        "    print(f\"  Content read from '{output_file}':\\n---\\n{read_content}--- \")\n",
        "except IOError as e:\n",
        "    print(f\"  Error reading from file: {e}\")\n",
        "finally:\n",
        "    # Clean up: remove the created file.\n",
        "    if os.path.exists(output_file):\n",
        "        os.remove(output_file)\n",
        "        print(f\"  Cleaned up: Removed '{output_file}'.\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 11. Classes and Objects ---\n",
        "# Classes are blueprints for creating objects (instances).\n",
        "print(\"--- Classes and Objects ---\")\n",
        "class Dog: # Define a class named Dog.\n",
        "    # The constructor method, called when a new object is created.\n",
        "    def __init__(self, name, breed):\n",
        "        self.name = name # Instance variable for the dog's name.\n",
        "        self.breed = breed # Instance variable for the dog's breed.\n",
        "\n",
        "    # An instance method.\n",
        "    def bark(self):\n",
        "        return f\"{self.name} says Woof!\"\n",
        "\n",
        "    # Another instance method.\n",
        "    def describe(self):\n",
        "        return f\"{self.name} is a {self.breed}.\"\n",
        "\n",
        "# Create objects (instances) of the Dog class.\n",
        "my_dog = Dog(\"Buddy\", \"Golden Retriever\")\n",
        "your_dog = Dog(\"Lucy\", \"Labrador\")\n",
        "\n",
        "# Access attributes and call methods of the objects.\n",
        "print(f\"  My dog's name: {my_dog.name}\")\n",
        "print(f\"  {my_dog.bark()}\")\n",
        "print(f\"  {your_dog.describe()}\")\n",
        "print(\"\\n\")\n",
        "\n",
        "# --- 12. Pandas DataFrames ---\n",
        "# DataFrames are 2-dimensional labeled data structures with columns of potentially different types.\n",
        "print(\"--- Pandas DataFrames ---\")\n",
        "\n",
        "# Create a dictionary to hold data.\n",
        "data = {\n",
        "    'Name': ['Alice', 'Bob', 'Charlie', 'David'],\n",
        "    'Age': [24, 27, 22, 32],\n",
        "    'City': ['New York', 'Los Angeles', 'Chicago', 'Houston']\n",
        "}\n",
        "\n",
        "# Create a Pandas DataFrame from the dictionary.\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(\"  Original DataFrame:\")\n",
        "display(df) # display() is often preferred over print() in Jupyter/Colab for DataFrames.\n",
        "\n",
        "# Select a single column.\n",
        "print(\"\\n  'Name' column:\")\n",
        "display(df['Name'])\n",
        "\n",
        "# Select multiple columns.\n",
        "print(\"\\n  'Name' and 'Age' columns:\")\n",
        "display(df[['Name', 'Age']])\n",
        "\n",
        "# Filter rows based on a condition.\n",
        "print(\"\\n  People older than 25:\")\n",
        "display(df[df['Age'] > 25])\n",
        "\n",
        "# Add a new column.\n",
        "df['Occupation'] = ['Software Engineer', 'Data Scientist', 'Designer', 'Manager']\n",
        "print(\"\\n  DataFrame with new 'Occupation' column:\")\n",
        "display(df)\n",
        "\n",
        "print(\"\\n\")\n",
        "\n",
        "print(\"Program execution complete.\")"
